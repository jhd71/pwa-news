{
  "version": 2,
  "builds": [
    {
      "src": "pages/api/**/*.js",
      "use": "@vercel/node"
    },
    {
      "src": "public_html/**/*",
      "use": "@vercel/static"
    }
  ],
  "rewrites": [
    { 
      "source": "/api/:path*",
      "destination": "/pages/api/:path*" 
    },
    { 
      "source": "/(.*)", 
      "destination": "/public_html/$1" 
    }
  ]
}
