{
    "name": "INFOS",
    "short_name": "INFOS",
    "description": "Votre portail d'actualités local",
    "start_url": "/?source=pwa",
    "scope": "/",
    "display": "standalone",
    "orientation": "portrait",
    "background_color": "#1a237e",
    "theme_color": "#1a237e",
    "icons": [
        {
            "src": "images/INFOS-96.png",
            "sizes": "96x96",
            "type": "image/png",
            "purpose": "any"
        },
        {
            "src": "images/INFOS-192.png",
            "sizes": "192x192",
            "type": "image/png",
            "purpose": "any"
        },
        {
            "src": "images/INFOS.png",
            "sizes": "512x512",
            "type": "image/png",
            "purpose": "any"
        },
        {
            "src": "images/badge-72x72.png",
            "sizes": "72x72",
            "type": "image/png",
            "purpose": "badge"
        }
    ],
    "shortcuts": [
        {
            "name": "Rechercher",
            "short_name": "Recherche",
            "description": "Effectuer une recherche",
            "url": "/?action=search",
            "icons": [{ "src": "images/INFOS.png", "sizes": "96x96" }]
        },
        {
            "name": "Chat",
            "short_name": "Chat",
            "description": "Ouvrir le chat",
            "url": "/?action=openchat",
            "icons": [{ "src": "images/INFOS-96.png", "sizes": "96x96" }]
        }
    ],
    "categories": ["news", "social"],
    "prefer_related_applications": false,
    "display_override": ["standalone", "minimal-ui"],
    "serviceworker": {
        "src": "/service-worker.js",
        "scope": "/",
        "use_cache": false,
        "update_via_cache": "none"
    },
    "permissions": [
        "notifications"
    ],
    "protocol_handlers": [
        {
            "protocol": "web+chat",
            "url": "/?chat=%s"
        }
    ],
    "share_target": {
        "action": "/share-target",
        "method": "GET",
        "params": {
            "title": "title",
            "text": "text",
            "url": "url"
        }
    },
    "notification_interactions": {
        "default": {
            "action": "/?action=openchat"
        }
    }
}
